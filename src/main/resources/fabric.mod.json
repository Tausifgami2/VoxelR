{
  "schemaVersion": 1,
  "id": "voxelr",
  "version": "${version}",
  "name": "VoxelR",
  "description": "GPU-accelerated voxel terrain renderer. No mesh building. No CPU lighting. One draw call.",
  "authors": [
    "BalancingLight"
  ],
  "contact": {
    "sources": "https://github.com/Tausifgami2/VoxelR"
  },
  "license": "All Rights Reserved",
  "icon": "assets/voxelr/voxelr.png",
  "environment": "client",
  "entrypoints": {
    "main": [
      "net.balancinglight.voxelr.VoxelRMod"
    ],
    "client": [
      "net.balancinglight.voxelr.VoxelRClient"
    ]
  },
  "mixins": [
    "voxelr.mixins.json"
  ],
  "accessWidener": "voxelr.accesswidener",
  "depends": {
    "fabricloader": ">=0.18.4",
    "fabric-api": "*",
    "minecraft": "~26.1"
  },
  "breaks": {
    "sodium": "*",
    "nvidium": "*"
  },
  "custom": {
    "modmenu": {
      "config_screen_factory": "net.balancinglight.voxelr.gui.screen.VoxelRConfigScreenFactory"
    }
  }
}
